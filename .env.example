# Postgres connection string for the database that contains invoice_audit_log.
# In production, use a READ-ONLY user. The schema is owned by the Solar Calculator v2 app.
DATABASE_URL=postgres://readonly:password@host:5432/dbname

# Toggles SSL on the pg pool (matches the existing Solar app's behavior).
NODE_ENV=production

# Optional. Defaults to 3000.
PORT=3000
