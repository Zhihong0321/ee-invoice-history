# ---- Choose ONE of the three modes below. ----

# (1) Direct Postgres — recommended when this app can reach the DB over TCP.
# DB_MODE=direct
# DATABASE_URL=postgres://readonly:password@host:5432/dbname

# (2) HTTP proxy — used when this app can't open a direct TCP socket to
#     Postgres. Mirrors the pattern in scripts/backfill-*-proxy.js in the
#     parent project.
# DB_MODE=proxy
# PG_PROXY_HOST=pg-proxy-production.up.railway.app
# PG_PROXY_DB_NAME=prod_main
# PG_PROXY_TOKEN=

# (3) Stub — no real DB. All queries return []. Healthz reports up. UI
#     loads but with no data. For UI dev / demos / screenshots only.
#     Never deploy with stub mode.
DB_MODE=stub

# Toggles SSL on the pg pool (only used in direct mode).
NODE_ENV=production

# Optional. Defaults to 3000.
PORT=3000
